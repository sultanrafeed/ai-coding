      "language": "typescript",
      "code": "// Time:  O(n)\n// Space: O(1)\n\n// generator\nfunction* factorial(n: number): Generator<number> {\n    for (let i = Math.min(n, 1), result = 1; i <= n; result *= ++i) {\n        yield result;\n    }\n};",
