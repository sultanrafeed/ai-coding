{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Problem",
  "type": "object",
  "required": ["id", "slug", "title", "difficulty", "descriptionHtml", "patterns", "testCases", "canonicalSolutions", "editorial"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
    "descriptionHtml": { "type": "string" },
    "patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Algorithmic patterns this problem tests, e.g. ['hash-table', 'two-pointers']"
    },
    "constraints": { "type": "object", "additionalProperties": { "type": "string" } },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input", "output"],
        "properties": {
          "input": { "type": "string" },
          "output": { "type": "string" },
          "explanation": { "type": "string" }
        }
      }
    },
    "testCases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input", "expectedOutput", "isHidden"],
        "properties": {
          "input": { "type": "string" },
          "expectedOutput": { "type": "string" },
          "isHidden": { "type": "boolean" }
        }
      }
    },
    "canonicalSolutions": {
      "type": "array",
      "description": "Verified correct solutions — primary source of truth for RAG, fine-tuning, and eval",
      "items": {
        "type": "object",
        "required": ["language", "code", "timeComplexity", "spaceComplexity"],
        "properties": {
          "language": { "type": "string" },
          "code": { "type": "string" },
          "timeComplexity": { "type": "string" },
          "spaceComplexity": { "type": "string" }
        }
      }
    },
    "editorial": {
      "type": "object",
      "required": ["approach", "explanation", "keyInsight", "commonMistakes"],
      "properties": {
        "approach": { "type": "string", "description": "Short name, e.g. 'Hash map complement lookup'" },
        "explanation": { "type": "string", "description": "Step-by-step reasoning — injected into AI context at inference time" },
        "keyInsight": { "type": "string", "description": "The one thing you need to see to solve this" },
        "commonMistakes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Used to generate synthetic buggy variants for fine-tuning data"
        }
      }
    }
  }
}
